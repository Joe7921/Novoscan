# ============================================================
# Novoscan Docker — 环境变量模板
#
# 使用方法：
#   cp .env.docker .env
#   然后编辑 .env 填入你的实际密钥
# ============================================================

# ────────────────────────────────────────────────────────────
# Docker 服务配置
# ────────────────────────────────────────────────────────────

# PostgreSQL 数据库
POSTGRES_DB=novoscan
POSTGRES_USER=novoscan
POSTGRES_PASSWORD=novoscan_secret_2026
POSTGRES_PORT=5432

# 数据库连接 URL（Docker 内部网络地址，app 容器使用此地址连接 db 容器）
DATABASE_URL=postgresql://novoscan:novoscan_secret_2026@db:5432/novoscan

# 数据库提供者（postgres = 自建 PostgreSQL / supabase = Supabase 云）
DATABASE_PROVIDER=postgres

# Redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# 应用端口
APP_PORT=3000

# ────────────────────────────────────────────────────────────
# 认证配置
# ────────────────────────────────────────────────────────────

# 认证提供者（nextauth = NextAuth.js / supabase = Supabase Auth）
AUTH_PROVIDER=nextauth

# NextAuth 密钥（⚠️ 生产环境请务必修改为随机长字符串！）
AUTH_SECRET=please-change-me-in-production

# ────────────────────────────────────────────────────────────
# 站点配置
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────
# Supabase（可选 — 留空则使用 IndexedDB 本地缓存）
# 如需连接外部 Supabase 云服务，请填入以下三项
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ────────────────────────────────────────────────────────────
# AI 模型密钥（至少配置一组）
# ────────────────────────────────────────────────────────────

# DeepSeek — 通用对话 + 深度推理
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MiniMax — 高速推理
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat
MINIMAX_MODEL=minimax-text-01

# Moonshot (Kimi) — 备选对话模型
MOONSHOT_API_KEY=

# ────────────────────────────────────────────────────────────
# 产业检索数据源（推荐至少配置 1 个）
# ────────────────────────────────────────────────────────────
BRAVE_API_KEY=
SERPAPI_KEY=
GITHUB_TOKEN=

# ────────────────────────────────────────────────────────────
# 学术检索数据源
# ────────────────────────────────────────────────────────────
CORE_API_KEY=
OPENALEX_EMAIL=
CROSSREF_EMAIL=

# ────────────────────────────────────────────────────────────
# Upstash Redis（可选 — 留空则使用内存回退）
# Docker 部署时可留空，速率限制将使用内存模式
# ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────────────────────────────────────────────────────────
# 其他可选配置
# ────────────────────────────────────────────────────────────
CRON_SECRET=
CRON_WEBHOOK_URL=
MCP_API_KEYS=
RESEND_API_KEY=
ADMIN_SECRET=
FINOPS_PRICING=

# ============================================================
# Novoscan Docker — 环境变量
#
# 用法：
#   cp .env.docker .env
#   编辑 .env 填入 AI 密钥（可选，默认 Mock 模式）
#   docker compose up -d
# ============================================================

# ── Docker 服务配置 ──
POSTGRES_DB=novoscan
POSTGRES_USER=novoscan
POSTGRES_PASSWORD=novoscan_secret_2026
APP_PORT=3000

# ── 站点配置 ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── 认证（默认关闭）──
AUTH_ENABLED=false
NEXT_PUBLIC_AUTH_ENABLED=false

# ── Mock AI（默认开启，零 API Key 体验完整流程）──
MOCK_AI=true

# ── AI 密钥（MOCK_AI=false 时至少填一个）──
DEEPSEEK_API_KEY=
# MINIMAX_API_KEY=
# MOONSHOT_API_KEY=

# ── 数据源（可选）──
# BRAVE_API_KEY=
# SERPAPI_KEY=
# GITHUB_TOKEN=
# CORE_API_KEY=
# OPENALEX_EMAIL=

# ============================================================
# Novoscan — 环境变量配置
# 复制此文件为 .env.local：  cp .env.example .env.local
#
# 🎉 零配置即可体验！直接 npm run dev 即可启动
#    MOCK_AI 已开启，无需任何 API Key
# ============================================================


# ══════════════════════════════════════════════════════════════
# 🚀 快速启动（零配置即可运行）
# ══════════════════════════════════════════════════════════════

# Mock AI 模式（默认开启 — 使用内置仿真数据，无需 API Key）
# 改为 false 后需填入至少一个 AI 模型密钥
MOCK_AI=true


# ══════════════════════════════════════════════════════════════
# 🔑 AI 模型密钥（MOCK_AI=false 时至少填一个）
# ══════════════════════════════════════════════════════════════

# DeepSeek — 通用对话 + 深度推理（推荐）
# 获取：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# MiniMax — 高速推理（可选）
# MINIMAX_API_KEY=

# Moonshot / Kimi — 备选（可选）
# MOONSHOT_API_KEY=

# Ollama 本地 AI（可选，零成本）
# 安装：https://ollama.com → ollama pull qwen2.5:14b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:14b


# ══════════════════════════════════════════════════════════════
# 🔍 数据源（可选，提升检索质量）
# ══════════════════════════════════════════════════════════════

# 产业检索
# BRAVE_API_KEY=           # https://brave.com/search/api/
# SERPAPI_KEY=              # https://serpapi.com/dashboard
# GITHUB_TOKEN=            # https://github.com/settings/tokens

# 学术检索
# CORE_API_KEY=            # https://core.ac.uk/services/api
# OPENALEX_EMAIL=          # 配置后进入高速访问通道
# CROSSREF_EMAIL=


# ══════════════════════════════════════════════════════════════
# ⚙️ 高级配置（大多数用户无需修改）
# 完整配置参考：docs/env-reference.md
# ══════════════════════════════════════════════════════════════

# 认证开关（默认关闭，自托管无需登录）
# AUTH_ENABLED=false
# NEXT_PUBLIC_AUTH_ENABLED=false

# 数据库（不配置则使用 noop 模式，数据不持久化）
# 可选值：noop | memory | sqlite | postgres | supabase
# DATABASE_PROVIDER=noop
#
# memory — 内存存储（进程重启后清空，适合开发测试）
# DATABASE_PROVIDER=memory
#
# sqlite — 本地文件数据库（单机部署推荐，需 npm install better-sqlite3）
# DATABASE_PROVIDER=sqlite
# SQLITE_PATH=./data/novoscan.db
#
# postgres — PostgreSQL（需 npm install pg）
# DATABASE_PROVIDER=postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/novoscan

# 站点域名
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════
# 🏪 Pro Marketplace 连接（可选，用于向中心市场发布插件）
# ══════════════════════════════════════════════════════════════

# Pro 端 URL（发布插件的目标服务器）
# NOVOSCAN_PRO_URL=https://novoscan.cn

# 开发者令牌（通过 Pro OAuth 授权获取）
# 获取方式：访问 {PRO_URL}/api/marketplace/oauth/authorize?redirect_uri=http://localhost:3000/callback
# NOVOSCAN_PRO_MARKETPLACE_TOKEN=

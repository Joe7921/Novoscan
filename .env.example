# ============================================================
# Novoscan 环境变量配置模板
# 复制此文件为 .env.local 并填入你的密钥
# cp .env.example .env.local
# ============================================================

# ────────────────────────────────────────────────────────────
# Supabase 数据库（可选 — 不配置时使用 IndexedDB 本地缓存）
# 用于云端历史记录、用户认证等持久化功能
# 获取地址：https://supabase.com/dashboard → 项目 Settings → API
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ────────────────────────────────────────────────────────────
# Mock AI 模式（本地开发利器 — 零 API 成本）
# ────────────────────────────────────────────────────────────
# true   → 回放模式：优先回放录制文件，无录制时使用内置 fixture
# record → 录制模式：调用真实 API，同时将响应写入 .mock-recordings/
# false  → 正常模式（默认）
MOCK_AI=false
# 模拟延迟（毫秒），用于测试前端 loading 状态和超时处理
# MOCK_AI_DELAY=3000
# 模拟随机错误率（0~1），用于测试前端降级逻辑
# MOCK_AI_ERROR_RATE=0.1

# ────────────────────────────────────────────────────────────
# AI 模型密钥（至少配置一组）
# 系统内建智能降级链，推荐配置多个以提升可用性
# ────────────────────────────────────────────────────────────

# DeepSeek — 通用对话 + 深度推理（DeepSeek V3 / R1）
# 获取地址：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MiniMax — 高速推理（minimax-text-01）
# 获取地址：https://platform.minimaxi.com/
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat
MINIMAX_MODEL=minimax-text-01

# Moonshot (Kimi) — 备选对话模型
# 获取地址：https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# ────────────────────────────────────────────────────────────
# 产业检索数据源（推荐至少配置 1 个）
# 缺少密钥时，对应数据源将静默跳过，不影响主流程
# ────────────────────────────────────────────────────────────

# Brave Search API — 独立索引的隐私优先搜索引擎
# 获取地址：https://brave.com/search/api/
BRAVE_API_KEY=
# BRAVE_API_BASE_URL=https://api.search.brave.com/res/v1/web/search

# SerpAPI — Google 搜索结果结构化 API
# 获取地址：https://serpapi.com/dashboard
SERPAPI_KEY=
# SERPAPI_BASE_URL=https://serpapi.com/search

# GitHub Token — 开源项目发现与技术栈分析
# 获取地址：https://github.com/settings/tokens
GITHUB_TOKEN=
# GITHUB_API_BASE_URL=https://api.github.com

# ────────────────────────────────────────────────────────────
# 学术检索数据源（推荐配置邮箱以提速）
# Base URL 均可覆盖，支持自建镜像或代理
# ────────────────────────────────────────────────────────────

# CORE — 全球最大开放获取论文聚合平台
# 获取地址：https://core.ac.uk/services/api
CORE_API_KEY=
# CORE_API_BASE_URL=https://api.core.ac.uk/v3

# OpenAlex / CrossRef — 学术数据库「礼貌池」邮箱
# 配置后进入 polite pool，获得更高请求速率
OPENALEX_EMAIL=
# OPENALEX_BASE_URL=https://api.openalex.org
CROSSREF_EMAIL=
# CROSSREF_BASE_URL=https://api.crossref.org/works

# arXiv — 预印本论文数据库（无需密钥）
# ARXIV_BASE_URL=http://export.arxiv.org/api/query

# ────────────────────────────────────────────────────────────
# Ollama 本地 AI（可选，零 API Key 成本）
# 无需申请密钥，本地运行即可使用
# 安装：https://ollama.com → ollama pull qwen2.5:14b
# ────────────────────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_API_KEY=            # 默认留空，Ollama 无需鉴权

# ────────────────────────────────────────────────────────────
# Cron 定时任务（可选）
# ────────────────────────────────────────────────────────────

# Cron 定时任务鉴权密钥（防止未授权调用）
CRON_SECRET=

# Cron Webhook 通知推送（可选，留空则不推送）
# 支持飞书 / Slack / 企业微信 / 自定义 URL，系统根据 URL 自动识别平台格式
CRON_WEBHOOK_URL=

# ────────────────────────────────────────────────────────────
# Upstash Redis（可选 — 跨实例速率限制）
# 不配置则使用内存回退，单实例场景无需配置
# ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ────────────────────────────────────────────────────────────
# MCP 服务 API Key（可选 — 格式: key:email,key2:email2）
# 用于 MCP 远程服务端点的访问鉴权
# ────────────────────────────────────────────────────────────
MCP_API_KEYS=

# ────────────────────────────────────────────────────────────
# 邮件推送（可选 — Resend）
# 用于合作伙伴申请通知等邮件功能
# 获取地址：https://resend.com/api-keys
# ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ────────────────────────────────────────────────────────────
# 站点配置
# ────────────────────────────────────────────────────────────

# 站点公开域名（用于分享链接、SEO 元数据、OG 图片等）
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# 站点显示名称
# NEXT_PUBLIC_SITE_NAME=Novoscan

# ────────────────────────────────────────────────────────────
# Admin 运维面板（可选）
# ────────────────────────────────────────────────────────────

# Admin API 鉴权密钥（用于 /api/admin/* 接口）
# 生成方式：openssl rand -hex 32
ADMIN_SECRET=

# FinOps 自定义费率（可选 — JSON 格式，覆盖默认费率）
# 格式：[{"name":"deepseek","inputPerMillion":1.40,"outputPerMillion":2.80}, ...]
# 不配置时使用内置默认费率
FINOPS_PRICING=

